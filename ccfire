#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Load .env if present
if [ -f .env ]; then
  set -a
  source .env
  set +a
fi

# Default to docker mode — preserves existing behavior for current users
MODE="${CCFIRE_MODE:-docker}"

# ─── Configure command ───
configure() {
  echo ""
  echo "  ccfire setup"
  echo "  ────────────"
  echo ""
  echo "  How do you want to run ccfire?"
  echo ""
  echo "  1) Docker   — runs in an isolated container (default)"
  echo "               Lightweight, no setup needed on your machine"
  echo "               Best for quick questions, code review, and research"
  echo ""
  echo "  2) Local    — runs on your machine directly"
  echo "               Claude can use your full toolchain (Java, Python, Go, etc.)"
  echo "               Best for building, testing, and running projects"
  echo ""

  while true; do
    printf "  Choose [1/2] (default: 1): "
    read -r choice
    case "${choice:-1}" in
      1) MODE="docker"; break ;;
      2) MODE="local"; break ;;
      *) echo "  Please enter 1 or 2" ;;
    esac
  done

  echo ""

  # Projects directory
  DEFAULT_DIR="${PROJECTS_DIR:-$HOME/repos}"
  printf "  Projects directory [%s]: " "$DEFAULT_DIR"
  read -r INPUT_DIR
  PROJECTS_DIR="${INPUT_DIR:-$DEFAULT_DIR}"

  # Expand ~ to HOME
  PROJECTS_DIR="${PROJECTS_DIR/#\~/$HOME}"

  if [ ! -d "$PROJECTS_DIR" ]; then
    echo ""
    echo "  Warning: $PROJECTS_DIR does not exist."
    printf "  Create it? [y/N]: "
    read -r create
    if [ "$create" = "y" ] || [ "$create" = "Y" ]; then
      mkdir -p "$PROJECTS_DIR"
      echo "  Created $PROJECTS_DIR"
    fi
  fi

  # Port
  DEFAULT_PORT="${PORT:-8283}"
  printf "  Port [%s]: " "$DEFAULT_PORT"
  read -r INPUT_PORT
  PORT="${INPUT_PORT:-$DEFAULT_PORT}"

  echo ""

  # Write .env
  cat > .env <<EOF
# Generated by ./ccfire configure
CCFIRE_MODE=$MODE
PROJECTS_DIR=$PROJECTS_DIR
PORT=$PORT
EOF

  echo "  Saved to .env"
  echo ""

  # Mode-specific guidance
  if [ "$MODE" = "local" ]; then
    MISSING=""
    if ! command -v node &>/dev/null; then
      MISSING="$MISSING  - Node.js (https://nodejs.org)\n"
    fi
    if ! command -v claude &>/dev/null; then
      MISSING="$MISSING  - Claude Code CLI (npm install -g @anthropic-ai/claude-code)\n"
    fi
    if [ -n "$MISSING" ]; then
      echo "  You'll need to install:"
      printf "$MISSING"
      echo ""
    fi
    echo "  Ready! Run ./ccfire start"
  else
    if ! command -v docker &>/dev/null; then
      echo "  You'll need Docker installed: https://docs.docker.com/get-docker/"
      echo ""
    fi
    echo "  Ready! Run:"
    echo "    ./ccfire start       # start the container"
    echo "    ./ccfire ssh         # authenticate Claude (first time only)"
    echo "    claude               # follow the auth flow, then exit"
  fi

  echo ""
}

# ─── Local mode ───
run_local() {
  PROJECTS_DIR="${PROJECTS_DIR:-$HOME/repos}"

  case "${1:-}" in
    start)
      if ! command -v node &>/dev/null; then
        echo "Error: Node.js is required. Install it from https://nodejs.org"
        exit 1
      fi
      if ! command -v claude &>/dev/null; then
        echo "Error: Claude Code CLI is required. Install with: npm install -g @anthropic-ai/claude-code"
        exit 1
      fi

      [ -d node_modules ] || npm install --production

      mkdir -p "$SCRIPT_DIR/outputs"

      # Kill existing process if running
      if [ -f "$SCRIPT_DIR/outputs/ccfire.pid" ]; then
        OLD_PID=$(cat "$SCRIPT_DIR/outputs/ccfire.pid")
        if kill -0 "$OLD_PID" 2>/dev/null; then
          kill "$OLD_PID" 2>/dev/null || true
          sleep 1
        fi
      fi

      echo "Starting ccfire in local mode..."
      echo "Projects: $PROJECTS_DIR"
      PROJECTS_ROOT="$PROJECTS_DIR" nohup node server.js > "$SCRIPT_DIR/outputs/ccfire.log" 2>&1 &
      echo $! > "$SCRIPT_DIR/outputs/ccfire.pid"
      echo "ccfire is running at http://localhost:${PORT:-8283} (pid: $!)"
      ;;
    stop)
      if [ -f "$SCRIPT_DIR/outputs/ccfire.pid" ]; then
        PID=$(cat "$SCRIPT_DIR/outputs/ccfire.pid")
        if kill -0 "$PID" 2>/dev/null; then
          kill "$PID"
          echo "ccfire stopped (pid: $PID)"
        else
          echo "ccfire is not running (stale pid: $PID)"
        fi
        rm -f "$SCRIPT_DIR/outputs/ccfire.pid"
      else
        echo "ccfire is not running (no pid file)"
      fi
      ;;
    restart)
      "$0" stop
      sleep 1
      "$0" start
      ;;
    logs)
      tail -f "$SCRIPT_DIR/outputs/ccfire.log"
      ;;
    status)
      if [ -f "$SCRIPT_DIR/outputs/ccfire.pid" ] && kill -0 "$(cat "$SCRIPT_DIR/outputs/ccfire.pid")" 2>/dev/null; then
        echo "ccfire is running (pid: $(cat "$SCRIPT_DIR/outputs/ccfire.pid"), mode: local, projects: ${PROJECTS_DIR})"
      else
        echo "ccfire is not running"
      fi
      ;;
    *)
      echo "Usage: ./ccfire {configure|start|stop|restart|logs|status}"
      exit 1
      ;;
  esac
}

# ─── Docker mode ───
run_docker() {
  case "${1:-}" in
    start)
      docker compose up -d --build
      echo "ccfire is running at http://localhost:${PORT:-8283}"
      ;;
    stop)
      docker compose down
      ;;
    restart)
      docker compose restart
      ;;
    ssh)
      docker exec -it -u ccfire ccfire /bin/bash
      ;;
    logs)
      docker compose logs -f
      ;;
    status)
      docker compose ps
      ;;
    *)
      echo "Usage: ./ccfire {configure|start|stop|restart|ssh|logs|status}"
      exit 1
      ;;
  esac
}

# ─── Main ───
case "${1:-}" in
  configure)
    configure
    ;;
  *)
    if [ "$MODE" = "local" ]; then
      run_local "$@"
    else
      run_docker "$@"
    fi
    ;;
esac
